{
  "name": "pi-vis",
  "version": "0.3.5",
  "description": "Electron GUI for pi.dev coding agent",
  "main": "./out/main/index.js",
  "author": "Pi-Vis",
  "homepage": ".",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rsingapuri/pi-vis.git"
  },
  "scripts": {
    "dev": "node scripts/ensure-worktree-dev.mjs && electron-vite dev",
    "dev:renderer": "node scripts/ensure-worktree-dev.mjs && vite --config vite.renderer.config.ts",
    "build": "node scripts/ensure-worktree-dev.mjs && npm run typecheck && electron-vite build && npm run copy-host",
    "copy-host": "mkdir -p out/resources/pi-session-host && cp resources/pi-session-host/*.mjs out/resources/pi-session-host/",
    "dist": "npm run build && electron-builder --mac",
    "dist:signed": "node scripts/dist-signed.mjs",
    "release": "node scripts/release.mjs",
    "typecheck": "node scripts/ensure-worktree-dev.mjs && tsc -b --noEmit",
    "lint": "node scripts/ensure-worktree-dev.mjs && biome check .",
    "format": "node scripts/ensure-worktree-dev.mjs && biome format --write .",
    "test": "node scripts/ensure-worktree-dev.mjs && vitest run",
    "test:e2e": "node scripts/ensure-worktree-dev.mjs && playwright test -c tests/e2e/playwright.config.mts",
    "test:render": "node scripts/ensure-worktree-dev.mjs && playwright test -c tests/render/playwright.config.mts",
    "test:full": "npm run typecheck && npm run lint && npm test && npm run build && npm run test:render && npm run test:e2e",
    "preview": "node scripts/ensure-worktree-dev.mjs && electron-vite preview",
    "make-icon": "bash scripts/make-icon.sh",
    "site:screenshots": "node scripts/site-screenshots.mjs"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.14.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff": "^8.0.4",
    "proper-lockfile": "^4.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.0.0",
    "turndown": "^7.2.4",
    "zod": "^3.22.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  }
}

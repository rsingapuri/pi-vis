{
  "name": "pi-vis",
  "version": "0.1.0",
  "description": "Electron GUI for pi.dev coding agent",
  "main": "./out/main/index.js",
  "author": "Pi-Vis",
  "homepage": ".",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rsingapuri/pi-vis.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build": "npm run typecheck && electron-vite build",
    "dist": "npm run build && electron-builder --mac",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.mts",
    "preview": "electron-vite preview",
    "make-icon": "bash scripts/make-icon.sh"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff": "^8.0.4",
    "proper-lockfile": "^4.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.0.0",
    "turndown": "^7.2.4",
    "zod": "^3.22.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  }
}

{
  "name": "pi-vis",
  "version": "0.1.0",
  "description": "Electron GUI for pi.dev coding agent",
  "main": "./out/main/index.js",
  "author": "Pi-Vis",
  "homepage": ".",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build": "npm run typecheck && electron-vite build",
    "dist": "npm run build && electron-builder --mac",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.mts",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "diff": "^8.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.0.0",
    "zod": "^3.22.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "allowScripts": {
    "@biomejs/biome@1.9.4": true,
    "electron@31.7.7": true,
    "esbuild@0.21.5": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
